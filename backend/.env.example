NODE_ENV=development
PORT=4000
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret_at_least_32_chars
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret_at_least_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
ADMIN_BOOTSTRAP_KEY=Admin@12345
DATABASE_URL=postgresql://locallink_app:change_me@localhost:5432/locallink
PGSSLMODE=disable
# Optional: override TLS certificate validation when SSL is enabled.
# true = strict CA/hostname verification, false = encrypted but relaxed verification.
# PGSSL_REJECT_UNAUTHORIZED=true
# Optional alternatives if DATABASE_URL is not set:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=locallink
# PGUSER=locallink_app
# PGPASSWORD=change_me
